# Local PostgreSQL database. Docker backend reaches the host through host.docker.internal.
DATABASE_URL=postgresql://postgres:changeme@host.docker.internal:5432/hr?sslmode=disable

# Redis
REDIS_PASSWORD=changeme

# JWT secrets. Generate strong values before production use.
JWT_SECRET=change-this-to-a-random-secret
JWT_REFRESH=change-this-to-another-random-secret

# Public backend URL used by browser-side frontend code.
API_URL=http://localhost:3041

# ZKTeco device
ZK_IP=192.128.69.33
ZK_PORT=4370
