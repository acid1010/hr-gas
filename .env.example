# Compose env file. Copy to .env at repo root before running `docker compose up`.

# ── Database ───────────────────────────────────────────────────────────────
# For docker-compose.yml (host Postgres):    use host.docker.internal
# For docker-compose.prod.yml (in-cluster):  ignored — backend uses postgres:5432
DATABASE_URL=postgresql://postgres:changeme@host.docker.internal:5432/hr?sslmode=disable

# Postgres credentials (used by docker-compose.prod.yml's postgres + migrate services)
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate strong values: openssl rand -hex 48
JWT_SECRET=change-this-to-a-random-secret
JWT_REFRESH=change-this-to-another-random-secret

# ── Frontend → Backend URL ─────────────────────────────────────────────────
# Baked into the client bundle at build time. Use the public origin reachable
# from the user's browser (LAN IP or domain), not an internal docker hostname.
API_URL=http://localhost:3041

# ── ZKTeco device ──────────────────────────────────────────────────────────
ZK_IP=192.128.69.33
ZK_PORT=4370
