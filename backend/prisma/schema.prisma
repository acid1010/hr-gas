generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nik             Decimal?          @db.Decimal
  name            String?           @db.VarChar(255)
  role            String?           @db.VarChar(255)
  access          String?           @db.VarChar(255)
  email           String?           @db.VarChar(255)
  departement     String?           @db.VarChar(255)
  section         String?           @db.VarChar(255)
  status          String?           @db.VarChar(255)
  worker_stats    String?           @db.VarChar(255)
  join_date       DateTime?         @db.Date
  username        String?           @db.VarChar(255)
  password        String?           @db.VarChar(255)
  hash            String?           @db.Char(255)
  link_image      String?           @db.VarChar(255)
  deletedAt       DateTime?         @db.Timestamp(6)
  overtime_detail overtime_detail[]
  overtime_permit overtime_permit[]
  performance     performance[]
  attendance      attendance[]
}

model overtime_permit {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?    @db.Uuid
  permission String?    @db.VarChar(255)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  overtime   overtime[]
  users      users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model performance {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  quarter     Int?
  status      String?   @db.VarChar(255)
  description String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model overtime {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  overtime_permit_id String?           @db.Uuid
  departement        String?           @db.VarChar(255)
  dates              DateTime?         @db.Date
  shift              Int?
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  updated_at         DateTime?         @default(now()) @db.Timestamp(6)
  overtime_permit    overtime_permit?  @relation(fields: [overtime_permit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  overtime_detail    overtime_detail[]
}

model attendance {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  device_uid String?   @db.VarChar(50)
  punch_time DateTime  @db.Timestamp(6)
  punch_type Int?
  created_at DateTime  @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([device_uid, punch_time])
}

model overtime_detail {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  necessary   String?   @db.VarChar(255)
  start_time  DateTime? @db.Date
  end_time    DateTime? @db.Date
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  overtime_id String?   @db.Uuid
  overtime    overtime? @relation(fields: [overtime_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
